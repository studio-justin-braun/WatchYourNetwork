#!/usr/bin/env bash
# wyn — WatchYourNetwork control CLI
# Installed to /usr/local/bin/wyn by install-server.sh
set -euo pipefail

CLI_VERSION="0.1.0"
WYN_REPO="https://github.com/studio-justin-braun/WatchYourNetwork"

SERVER_SERVICE="wyn-server"
AGENT_SERVICE="wyn-agent"
SERVER_INSTALL="/opt/wyn-server"
AGENT_INSTALL="/opt/wyn-agent"
SERVER_CONFIG="/etc/wyn/server.yaml"
AGENT_CONFIG="/etc/wyn/agent.conf"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "${GREEN}✓ $*${NC}"; }
info() { echo -e "${CYAN}  $*${NC}"; }
warn() { echo -e "${YELLOW}⚠ $*${NC}"; }
err()  { echo -e "${RED}✗ $*${NC}" >&2; }
sep()  { echo -e "${BLUE}────────────────────────────────────────${NC}"; }

need_root() {
    if [[ $EUID -ne 0 ]]; then
        err "Run with sudo: sudo wyn $*"
        exit 1
    fi
}

# ── wyn help ──────────────────────────────────────────────────────────────────

cmd_help() {
    echo ""
    echo -e "  ${BOLD}${BLUE}wyn${NC} — WatchYourNetwork  (CLI v${CLI_VERSION})"
    echo ""
    echo -e "  ${BOLD}Service control${NC}"
    echo "    wyn status              Show server + agent status"
    echo "    wyn start  [server|agent|all]"
    echo "    wyn stop   [server|agent|all]"
    echo "    wyn restart [server|agent|all]"
    echo "    wyn logs   [server|agent] [-n N]   default: 50 lines"
    echo ""
    echo -e "  ${BOLD}Maintenance${NC}"
    echo "    wyn update              Download + install latest version from GitHub"
    echo "    wyn uninstall [server|agent|all]"
    echo "    wyn version             Show installed versions"
    echo ""
    echo -e "  ${BOLD}Config & access${NC}"
    echo "    wyn config              Edit agent config (interactive)"
    echo "    wyn open                Print + open web UI URL in browser"
    echo ""
}

# ── wyn status ────────────────────────────────────────────────────────────────

cmd_status() {
    echo ""
    sep
    echo -e "  ${BOLD}WatchYourNetwork — Status${NC}"
    sep

    for svc in "$SERVER_SERVICE" "$AGENT_SERVICE"; do
        if ! systemctl list-unit-files "${svc}.service" &>/dev/null 2>&1; then
            printf "  %-22s %s\n" "$svc" "not installed"
            continue
        fi
        local active enabled
        active=$(systemctl is-active  "$svc" 2>/dev/null || echo "inactive")
        enabled=$(systemctl is-enabled "$svc" 2>/dev/null || echo "disabled")
        local col="$RED"
        [[ "$active" == "active" ]] && col="$GREEN"
        printf "  %-22s " "$svc"
        echo -e "${col}${active}${NC}  (${enabled})"
    done

    sep

    if systemctl is-active --quiet "$SERVER_SERVICE" 2>/dev/null; then
        local port ip
        port=$(python3 -c "import yaml; c=yaml.safe_load(open('$SERVER_CONFIG')); print(c.get('server',{}).get('http_port',8080))" 2>/dev/null || echo "8080")
        ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
        info "Web UI  →  http://${ip}:${port}"
    fi
    echo ""
}

# ── wyn start / stop / restart ────────────────────────────────────────────────

cmd_service() {
    local action="$1"; shift
    local target="${1:-all}"
    need_root "$action $target"

    local services=()
    case "$target" in
        server) services=("$SERVER_SERVICE") ;;
        agent)  services=("$AGENT_SERVICE") ;;
        all)    services=("$SERVER_SERVICE" "$AGENT_SERVICE") ;;
        *) err "Unknown target '$target' — use: server, agent, or all"; exit 1 ;;
    esac

    for svc in "${services[@]}"; do
        if ! systemctl list-unit-files "${svc}.service" &>/dev/null 2>&1; then
            warn "$svc not installed — skipping"
            continue
        fi
        echo -e "${YELLOW}${action^}ing $svc …${NC}"
        systemctl "$action" "$svc" || true
        sleep 0.6
        local st
        st=$(systemctl is-active "$svc" 2>/dev/null || echo "inactive")
        if [[ "$action" == "stop" ]]; then
            [[ "$st" != "active" ]] && ok "$svc stopped" || warn "$svc still running"
        else
            [[ "$st" == "active" ]] && ok "$svc is running" || warn "$svc: $st — check: journalctl -u $svc -n 20"
        fi
    done
}

# ── wyn logs ──────────────────────────────────────────────────────────────────

cmd_logs() {
    local target="server" lines="50"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) lines="${2:-50}"; shift 2 ;;
            server|agent) target="$1"; shift ;;
            *) shift ;;
        esac
    done

    local svc
    case "$target" in
        server) svc="$SERVER_SERVICE" ;;
        agent)  svc="$AGENT_SERVICE" ;;
        *) err "Unknown target: $target"; exit 1 ;;
    esac

    if ! systemctl list-unit-files "${svc}.service" &>/dev/null 2>&1; then
        err "$svc not installed"; exit 1
    fi
    journalctl -u "$svc" -n "$lines" --no-pager
}

# ── wyn update ────────────────────────────────────────────────────────────────

cmd_update() {
    need_root update

    echo ""
    echo -e "${BOLD}  WYN Update${NC}"
    sep

    local tmp
    tmp=$(mktemp -d)
    trap "rm -rf '$tmp'" EXIT

    info "Downloading latest from GitHub…"
    local url="${WYN_REPO}/archive/refs/heads/main.tar.gz"
    if ! curl -fsSL "$url" -o "$tmp/wyn.tar.gz"; then
        err "Download failed. Verify the repo URL is correct in /usr/local/bin/wyn"
        err "Current: $url"
        exit 1
    fi
    tar -xzf "$tmp/wyn.tar.gz" -C "$tmp" --strip-components=1
    ok "Downloaded"

    # Stop services
    local srv_was_running=false agent_was_running=false
    systemctl is-active --quiet "$SERVER_SERVICE" 2>/dev/null && srv_was_running=true
    systemctl is-active --quiet "$AGENT_SERVICE"  2>/dev/null && agent_was_running=true
    $srv_was_running  && systemctl stop "$SERVER_SERVICE" && info "Stopped server"
    $agent_was_running && systemctl stop "$AGENT_SERVICE"  && info "Stopped agent"

    # Update server
    if [[ -d "$SERVER_INSTALL" ]]; then
        cp "$tmp/wyn-server/server.py"         "$SERVER_INSTALL/"
        cp "$tmp/wyn-server/requirements.txt"  "$SERVER_INSTALL/"
        [[ -d "$tmp/wyn-ui" ]] && rsync -a --delete "$tmp/wyn-ui/" "$SERVER_INSTALL/wyn-ui/" 2>/dev/null \
            || cp -r "$tmp/wyn-ui/." "$SERVER_INSTALL/wyn-ui/"
        ok "Server files updated"
        local pip_flags=""
        python3 -m pip install --help 2>/dev/null | grep -q "break-system-packages" \
            && pip_flags="--break-system-packages --ignore-installed"
        python3 -m pip install $pip_flags -r "$SERVER_INSTALL/requirements.txt" -q
        ok "Server packages updated"
    fi

    # Update agent
    if [[ -d "$AGENT_INSTALL" ]]; then
        cp "$tmp/wyn-agent/agent.py"       "$AGENT_INSTALL/"
        [[ -f "$tmp/wyn-agent/change-conf.sh" ]] && cp "$tmp/wyn-agent/change-conf.sh" "$AGENT_INSTALL/"
        ok "Agent files updated"
    fi

    # Update wyn CLI itself
    [[ -f "$tmp/wyn-ctl/wyn" ]] \
        && cp "$tmp/wyn-ctl/wyn" /usr/local/bin/wyn \
        && chmod +x /usr/local/bin/wyn \
        && ok "wyn CLI updated"

    systemctl daemon-reload

    $srv_was_running   && systemctl start "$SERVER_SERVICE" && ok "Server restarted"
    $agent_was_running && systemctl start "$AGENT_SERVICE"  && ok "Agent restarted"

    echo ""
    ok "Update complete!"
    echo ""
}

# ── wyn uninstall ─────────────────────────────────────────────────────────────

cmd_uninstall() {
    local target="${1:-all}"
    need_root "uninstall $target"

    echo ""
    warn "This will remove WYN ${target} files and systemd service(s)."
    read -rp "  Continue? [y/N]: " confirm
    [[ "${confirm,,}" != "y" ]] && { info "Aborted."; exit 0; }

    local rm_server=false rm_agent=false
    case "$target" in
        server) rm_server=true ;;
        agent)  rm_agent=true ;;
        all)    rm_server=true; rm_agent=true ;;
        *) err "Unknown target: $target"; exit 1 ;;
    esac

    if $rm_server; then
        systemctl stop    "$SERVER_SERVICE" 2>/dev/null || true
        systemctl disable "$SERVER_SERVICE" 2>/dev/null || true
        rm -f "/etc/systemd/system/${SERVER_SERVICE}.service"
        rm -rf "$SERVER_INSTALL"
        ok "Server removed"
    fi

    if $rm_agent; then
        systemctl stop    "$AGENT_SERVICE" 2>/dev/null || true
        systemctl disable "$AGENT_SERVICE" 2>/dev/null || true
        rm -f "/etc/systemd/system/${AGENT_SERVICE}.service"
        rm -rf "$AGENT_INSTALL"
        ok "Agent removed"
    fi

    if $rm_server && $rm_agent; then
        read -rp "  Remove /etc/wyn config directory? [y/N]: " rm_cfg
        [[ "${rm_cfg,,}" == "y" ]] && rm -rf /etc/wyn && ok "Config removed"
        rm -f /usr/local/bin/wyn
        ok "wyn CLI removed"
    fi

    systemctl daemon-reload
    echo ""
    ok "Uninstall complete."
    echo ""
}

# ── wyn config ────────────────────────────────────────────────────────────────

cmd_config() {
    local script="$AGENT_INSTALL/change-conf.sh"
    if [[ ! -f "$script" ]]; then
        err "change-conf.sh not found at $script"
        err "Is the agent installed? Run: install-agent.sh"
        exit 1
    fi
    bash "$script" "${1:-$AGENT_CONFIG}"
}

# ── wyn open ──────────────────────────────────────────────────────────────────

cmd_open() {
    local port="8080" ip
    [[ -f "$SERVER_CONFIG" ]] && \
        port=$(python3 -c "import yaml; c=yaml.safe_load(open('$SERVER_CONFIG')); print(c.get('server',{}).get('http_port',8080))" 2>/dev/null || echo "8080")
    ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
    local url="http://${ip}:${port}"
    info "Web UI → $url"
    if command -v xdg-open &>/dev/null; then xdg-open "$url" 2>/dev/null &
    elif command -v open &>/dev/null;    then open "$url" 2>/dev/null &
    fi
}

# ── wyn version ───────────────────────────────────────────────────────────────

cmd_version() {
    echo "wyn CLI  v${CLI_VERSION}"
    [[ -f "$SERVER_INSTALL/server.py" ]] && \
        printf "server   v%s\n" "$(grep -m1 'VERSION = ' "$SERVER_INSTALL/server.py" | grep -oP '"[^"]+"' | tr -d '"')"
    [[ -f "$AGENT_INSTALL/agent.py" ]] && \
        printf "agent    v%s\n" "$(grep -m1 'VERSION = ' "$AGENT_INSTALL/agent.py"   | grep -oP '"[^"]+"' | tr -d '"')"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    status)              cmd_status ;;
    start)               cmd_service start   "${1:-all}" ;;
    stop)                cmd_service stop    "${1:-all}" ;;
    restart)             cmd_service restart "${1:-all}" ;;
    logs)                cmd_logs "$@" ;;
    update)              cmd_update ;;
    uninstall)           cmd_uninstall "${1:-all}" ;;
    config)              cmd_config "$@" ;;
    open)                cmd_open ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help)      cmd_help ;;
    *)
        err "Unknown command: $CMD"
        cmd_help
        exit 1
        ;;
esac
